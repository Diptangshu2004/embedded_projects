#include <SoftwareSerial.h>

SoftwareSerial mySerial(10, 11); // RX | TX
int command ;

void setup() {
   Serial.begin(9600);
   mySerial.begin(9600);
   Serial.println("You're connected via Bluetooth");

   pinMode(2,OUTPUT);   // left forward
   pinMode(3,OUTPUT);   // left reverse
   pinMode(4,OUTPUT);   // right forward
   pinMode(5,OUTPUT);   // right reverse
}

void loop() {
   if (mySerial.available())
   {
    command=(mySerial.read());

    if (command=='F')
    {
      Serial.println("Forward");
      digitalWrite(2,HIGH);
      digitalWrite(3,LOW);
      digitalWrite(4,HIGH);
      digitalWrite(5,LOW);           
    }
    
    else if (command=='B')
    {
      Serial.println("Reverse");
      digitalWrite(2,LOW);
      digitalWrite(3,HIGH);
      digitalWrite(4,LOW);
      digitalWrite(5,HIGH);
    }
    
    else if (command=='L')
    {
      Serial.println("Left");
      digitalWrite(2,LOW);
      digitalWrite(3,LOW);
      digitalWrite(4,HIGH);
      digitalWrite(5,LOW);
    }

    else if (command=='R')
    {
      Serial.println("Right");
      digitalWrite(2,HIGH);
      digitalWrite(3,LOW);
      digitalWrite(4,LOW);
      digitalWrite(5,LOW);
    }

    else if (command=='S')
    {
      Serial.println("Stop");
      digitalWrite(2,LOW);
      digitalWrite(3,LOW);
      digitalWrite(4,LOW);
      digitalWrite(5,LOW);
    }

   delay(30);
  }
}
