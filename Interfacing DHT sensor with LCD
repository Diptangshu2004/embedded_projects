#include <LiquidCrystal_I2C.h>
#include <Wire.h>
#include <DHT.h>
#define DHTPIN 6
DHT dht (DHTPIN,DHT11);
float tempC,humidity;
LiquidCrystal_I2C lcd(0x27,16,2);
void setup() {
 lcd.begin(16,2);
 dht.begin();
 lcd.backlight();
 lcd.setBacklight(HIGH);
 lcd.print("Initializing..");
 delay(2000);
 lcd.clear();


}

void loop() {
 
 humidity= dht.readHumidity();
 tempC= dht.readTemperature();

 if(isnan(humidity)||isnan(tempC))
 {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("ERROR");
  delay(2000);
  return;
 }
 
  lcd.setCursor(0,0);
  lcd.print("TEMP: ");
  lcd.setCursor(7,0);
  lcd.print(tempC);
  lcd.print(char(223));
  lcd.print("C");
 
  lcd.setCursor(0,1);
  lcd.print("Humidity:");
  lcd.setCursor(10,1);
  lcd.print(humidity);

}
